{
  "name": "gemini-local-agent",
  "description": "Bridge between Google Gemini web UI and local Ubuntu via Native Messaging",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:browser:smoke": "python3 test/e2e_browser.py 9222",
    "test:closed-loop": "python3 -m test.closed_loop.run --tier A",
    "test:closed-loop:live": "python3 -m test.closed_loop.run --tier B",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wxt": "^0.20.25"
  }
}
