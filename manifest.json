{
  "manifest_version": 3,
  "name": "Gemini Local Agent",
  "version": "1.0",
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*"],
      "js": ["content.js"]
    }
  ]
}